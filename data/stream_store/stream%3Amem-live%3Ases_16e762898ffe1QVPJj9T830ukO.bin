:false},"title":"beibu-mall/mall-inventory/mall-inventory-server/src/main/java/com/beibu/mall/inventory/entity/InventoryItem.java","tool_input":"{\"filePath\":\"/home/administrator/BeibuMall/beibu-mall/mall-inventory/mall-inventory-server/src/main/java/com/beibu/mall/inventory/entity/InventoryItem.java\"}","tool_name":"read","tool_output":"<path>/home/administrator/BeibuMall/beibu-mall/mall-inventory/mall-inventory-server/src/main/java/com/beibu/mall/inventory/entity/InventoryItem.java</path>\n<type>file</type>\n<content>\n1: package com.beibu.mall.inventory.entity;\n2: \n3: import com.baomidou.mybatisplus.annotation.*;\n4: import lombok.Data;\n5: \n6: import java.time.LocalDateTime;\n7: \n8: /**\n9:  * еә“еӯҳе®һдҪ“зұ»\n10:  *\n11:  * еҜ№еә”ж•°жҚ®еә“ inventory_item иЎЁгҖӮ\n12:  * @TableName(\"inventory_item\") е‘ҠиҜү MyBatis-Plus иҝҷдёӘзұ»еҜ№еә”е“Әеј иЎЁгҖӮ\n13:  *\n14:  * еӯ—ж®өиҜҙжҳҺпјҡ\n15:  * - availableStockпјҡеҸҜз”Ёеә“еӯҳпјҢеҪ“еүҚеҸҜд»ҘеҚ–з»ҷз”ЁжҲ·зҡ„ж•°йҮҸ\n16:  * - lockedStockпјҡйў„еҚ еә“еӯҳпјҢиў«и®ўеҚ•й”Ғе®ҡдҪҶиҝҳжІЎзңҹжӯЈжүЈеҮҸзҡ„ж•°йҮҸ\n17:  * - totalStockпјҡжҖ»еә“еӯҳ = еҸҜз”Ёеә“еӯҳ + йў„еҚ еә“еӯҳ\n18:  * - versionпјҡзүҲжң¬еҸ·пјҢд№җи§Ӯй”Ғз”ЁпјҢжҜҸж¬Ўжӣҙж–°+1пјҢйҳІжӯўе№¶еҸ‘и¶…еҚ–\n19:  */\n20: @Data\n21: @TableName(\"inventory_item\")\n22: public class InventoryItem {\n23: \n24:     /**\n25:      * дё»й”®ID\n26:      * @TableId иЎЁзӨәиҝҷжҳҜдё»й”®\n27:      * IdType.ASSIGN_ID = йӣӘиҠұз®—жі•з”ҹжҲҗ IDпјҲеҲҶеёғејҸзҺҜеўғдёӢдҝқиҜҒе”ҜдёҖпјү\n28:      */\n29:     @TableId(type = IdType.ASSIGN_ID)\n30:     private Long id;\n31: \n32:     /**\n33:      * е•Ҷе“ҒSKU ID\n34:      * SKU = Stock Keeping UnitпјҢеә“еӯҳйҮҸеҚ•дҪҚ\n35:      * жҜ”еҰӮ\"зәўиүІXLз ҒTжҒӨ\"е°ұжҳҜдёҖдёӘSKUпјҢжңүзӢ¬з«Ӣзҡ„еә“еӯҳж•°йҮҸ\n36:      */\n37:     private String skuId;\n38: \n39:     /** е•Ҷе“ҒID */\n40:     private String productId;\n41: \n42:     /** е•Ҷе“ҒеҗҚз§°пјҲеҶ—дҪҷеӯ—ж®өпјҢйҒҝе…Қе…іиҒ”жҹҘиҜўпјү */\n43:     private String productName;\n44: \n45:     /**\n46:      * еҸҜз”Ёеә“еӯҳ\n47:      * еҪ“еүҚеҸҜд»ҘеҚ–з»ҷз”ЁжҲ·зҡ„ж•°йҮҸ = жҖ»еә“еӯҳ - йў„еҚ еә“еӯҳ\n48:      */\n49:     private Integer availableStock;\n50: \n51:     /**\n52:      * йў„еҚ еә“еӯҳ\n53:      * иў«и®ўеҚ•й”Ғе®ҡдҪҶиҝҳжІЎзңҹжӯЈжүЈеҮҸзҡ„ж•°йҮҸ\n54:      * жҜ”еҰӮдёӢеҚ•ж—¶е…Ҳйў„еҚ 1дёӘпјҢж”Ҝд»ҳжҲҗеҠҹеҗҺеҶҚзңҹжӯЈжүЈеҮҸ\n55:      */\n56:     private Integer lockedStock;\n57: \n58:     /**\n59:      * жҖ»еә“еӯҳ\n60:      * = еҸҜз”Ёеә“еӯҳ + йў„еҚ еә“еӯҳ\n61:      * иҝҷдёӘеӯ—ж®өжҳҜеҶ—дҪҷзҡ„пјҢж–№дҫҝжҹҘиҜўпјҢйҒҝе…ҚжҜҸж¬ЎйғҪиҰҒи®Ўз®—\n62:      */\n63:     private Integer totalStock;\n64: \n65:     /**\n66:      * зүҲжң¬еҸ·\n67:      * жҜҸж¬Ўжӣҙж–°ж—¶+1пјҢз”ЁдәҺи®°еҪ•еҸҳжӣҙж¬Ўж•°гҖӮ\n68:      * жіЁж„ҸпјҡйҳІи¶…еҚ–йқ зҡ„жҳҜеҺҹеӯҗ SQL дёӯзҡ„ available_stock >= quantity жқЎд»¶пјҢ\n69:      * дёҚжҳҜйқ  version жЈҖжҹҘгҖӮиҝҷйҮҢдёҚеҠ  @Version жіЁи§ЈпјҢйҒҝе…ҚиҜҜеҜјгҖӮ\n70:      */\n71:     private Integer version;\n72: \n73:     /** еҲӣе»әж—¶й—ҙ */\n74:     private LocalDateTime createTime;\n75: \n76:     /** жӣҙж–°ж—¶й—ҙ */\n77:     private LocalDateTime updateTime;\n78: }\n\n(End of file - total 78 lines)\n</content>"},"sessionId":"ses_16e762898ffe1QVPJj9T830ukO","timestamp":"2026-06-04T07:30:56.738Z","toolInput":"{\"filePath\":\"/home/administrator/BeibuMall/beibu-mall/mall-inventory/mall-inventory-server/src/main/java/com/beibu/mall/inventory/entity/InventoryItem.java\"}","toolName":"read","toolOutput":"<path>/home/administrator/BeibuMall/beibu-mall/mall-inventory/mall-inventory-server/src/main/java/com/beibu/mall/inventory/entity/InventoryItem.java</path>\n<type>file</type>\n<content>\n1: package com.beibu.mall.inventory.entity;\n2: \n3: import com.baomidou.mybatisplus.annotation.*;\n4: import lombok.Data;\n5: \n6: import java.time.LocalDateTime;\n7: \n8: /**\n9:  * еә“еӯҳе®һдҪ“зұ»\n10:  *\n11:  * еҜ№еә”ж•°жҚ®еә“ inventory_item иЎЁгҖӮ\n12:  * @TableName(\"inventory_item\") е‘ҠиҜү MyBatis-Plus иҝҷдёӘзұ»еҜ№еә”е“Әеј иЎЁгҖӮ\n13:  *\n14:  * еӯ—ж®өиҜҙжҳҺпјҡ\n15:  * - availableStockпјҡеҸҜз”Ёеә“еӯҳпјҢеҪ“еүҚеҸҜд»ҘеҚ–з»ҷз”ЁжҲ·зҡ„ж•°йҮҸ\n16:  * - lockedStockпјҡйў„еҚ еә“еӯҳпјҢиў«и®ўеҚ•й”Ғе®ҡдҪҶиҝҳжІЎзңҹжӯЈжүЈеҮҸзҡ„ж•°йҮҸ\n17:  * - totalStockпјҡжҖ»еә“еӯҳ = еҸҜз”Ёеә“еӯҳ + йў„еҚ еә“еӯҳ\n18:  * - versionпјҡзүҲжң¬еҸ·пјҢд№җи§Ӯй”Ғз”ЁпјҢжҜҸж¬Ўжӣҙж–°+1пјҢйҳІжӯўе№¶еҸ‘и¶…еҚ–\n19:  */\n20: @Data\n21: @TableName(\"inventory_item\")\n22: public class InventoryItem {\n23: \n24:     /**\n25:      * дё»й”®ID\n26:      * @TableId иЎЁзӨәиҝҷжҳҜдё»й”®\n27:      * IdType.ASSIGN_ID = йӣӘиҠұз®—жі•з”ҹжҲҗ IDпјҲеҲҶеёғејҸзҺҜеўғдёӢдҝқиҜҒе”ҜдёҖпјү\n28:      */\n29:     @TableId(type = IdType.ASSIGN_ID)\n30:     private Long id;\n31: \n32:     /**\n33:      * е•Ҷе“ҒSKU ID\n34:      * SKU = Stock Keeping UnitпјҢеә“еӯҳйҮҸеҚ•дҪҚ\n35:      * жҜ”еҰӮ\"зәўиүІXLз ҒTжҒӨ\"е°ұжҳҜдёҖдёӘSKUпјҢжңүзӢ¬з«Ӣзҡ„еә“еӯҳж•°йҮҸ\n36:      */\n37:     private String skuId;\n38: \n39:     /** е•Ҷе“ҒID */\n40:     private String productId;\n41: \n42:     /** е•Ҷе“ҒеҗҚз§°пјҲеҶ—дҪҷеӯ—ж®өпјҢйҒҝе…Қе…іиҒ”жҹҘиҜўпјү */\n43:     private String productName;\n44: \n45:     /**\n46:      * еҸҜз”Ёеә“еӯҳ\n47:      * еҪ“еүҚеҸҜд»ҘеҚ–з»ҷз”ЁжҲ·зҡ„ж•°йҮҸ = жҖ»еә“еӯҳ - йў„еҚ еә“еӯҳ\n48:      */\n49:     private Integer availableStock;\n50: \n51:     /**\n52:      * йў„еҚ еә“еӯҳ\n53:      * иў«и®ўеҚ•й”Ғе®ҡдҪҶиҝҳжІЎзңҹжӯЈжүЈеҮҸзҡ„ж•°йҮҸ\n54:      * жҜ”еҰӮдёӢеҚ•ж—¶е…Ҳйў„еҚ 1дёӘпјҢж”Ҝд»ҳжҲҗеҠҹеҗҺеҶҚзңҹжӯЈжүЈеҮҸ\n55:      */\n56:     private Integer lockedStock;\n57: \n58:     /**\n59:      * жҖ»еә“еӯҳ\n60:      * = еҸҜз”Ёеә“еӯҳ + йў„еҚ еә“еӯҳ\n61:      * иҝҷдёӘеӯ—ж®өжҳҜеҶ—дҪҷзҡ„пјҢж–№дҫҝжҹҘиҜўпјҢйҒҝе…ҚжҜҸж¬ЎйғҪиҰҒи®Ўз®—\n62:      */\n63:     private Integer totalStock;\n64: \n65:     /**\n66:      * зүҲжң¬еҸ·\n67:      * жҜҸж¬Ўжӣҙж–°ж—¶+1пјҢз”ЁдәҺи®°еҪ•еҸҳжӣҙж¬Ўж•°гҖӮ\n68:      * жіЁж„ҸпјҡйҳІи¶…еҚ–йқ зҡ„жҳҜеҺҹеӯҗ SQL дёӯзҡ„ available_stock >= quantity жқЎд»¶пјҢ\n69:      * дёҚжҳҜйқ  version жЈҖжҹҘгҖӮиҝҷйҮҢдёҚеҠ  @Version жіЁи§ЈпјҢйҒҝе…ҚиҜҜеҜјгҖӮ\n70:      */\n71:     private Integer version;\n72: \n73:     /** еҲӣе»әж—¶й—ҙ */\n74:     private LocalDateTime createTime;\n75: \n76:     /** жӣҙж–°ж—¶й—ҙ */\n77:     private LocalDateTime updateTime;\n78: }\n\n(End of file - total 78 lines)\n</content>"},"type":"raw"}}„ҡ␀|Yюя