port java.util.*;\n\n/**\n * иҙӯзү©иҪҰжңҚеҠЎе®һзҺ°зұ»\n *","truncated":false},"title":"beibu-mall/mall-cart/mall-cart-server/src/main/java/com/beibu/mall/cart/service/impl/CartServiceImpl.java","tool_input":"{\"filePath\":\"/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/main/java/com/beibu/mall/cart/service/impl/CartServiceImpl.java\"}","tool_name":"read","tool_output":"<path>/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/main/java/com/beibu/mall/cart/service/impl/CartServiceImpl.java</path>\n<type>file</type>\n<content>\n1: package com.beibu.mall.cart.service.impl;\n2: \n3: import com.beibu.mall.cart.api.dto.CartDTO;\n4: import com.beibu.mall.cart.api.dto.CartItemVO;\n5: import com.beibu.mall.cart.service.CartService;\n6: import com.beibu.mall.common.exception.BizException;\n7: import com.beibu.mall.common.result.Result;\n8: import com.beibu.mall.product.api.dto.SkuVO;\n9: import com.beibu.mall.product.api.feign.ProductFeignClient;\n10: import lombok.RequiredArgsConstructor;\n11: import lombok.extern.slf4j.Slf4j;\n12: import org.springframework.data.redis.core.HashOperations;\n13: import org.springframework.data.redis.core.RedisTemplate;\n14: import org.springframework.stereotype.Service;\n15: \n16: import java.util.*;\n17: \n18: /**\n19:  * иҙӯзү©иҪҰжңҚеҠЎе®һзҺ°зұ»\n20:  *\n21:  * ж ёеҝғжҖқи·Ҝпјҡ\n22:  * иҙӯзү©иҪҰж•°жҚ®еӯҳеңЁ Redis зҡ„ Hash з»“жһ„дёӯгҖӮ\n23:  *\n24:  * Redis Hash з»“жһ„зӨәж„Ҹпјҡ\n25:  * Key: cart:1001пјҲз”ЁжҲ·ID=1001 зҡ„иҙӯзү©иҪҰпјү\n26:  * в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n27:  * в”Ӯ  Hash Key  в”Ӯ Hash Value  в”Ӯ\n28:  * в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\n29:  * в”Ӯ \"10086\"    в”Ӯ 2           в”Ӯ  вҶҗ SKU ID=10086пјҢж•°йҮҸ=2\n30:  * в”Ӯ \"10087\"    в”Ӯ 1           в”Ӯ  вҶҗ SKU ID=10087пјҢж•°йҮҸ=1\n31:  * в”Ӯ \"10090\"    в”Ӯ 3           в”Ӯ  вҶҗ SKU ID=10090пјҢж•°йҮҸ=3\n32:  * в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n33:  *\n34:  * дёәд»Җд№Ҳз”Ё Hash иҖҢдёҚжҳҜ Stringпјҹ\n35:  * - String еӯҳж•ҙдёӘиҙӯзү©иҪҰпјҡж”№дёҖдёӘе•Ҷе“Ғж•°йҮҸпјҢиҰҒиҜ»ж•ҙдёӘ JSON вҶ’ ж”№ вҶ’ еҶҷеӣһеҺ»пјҲе№¶еҸ‘дёҚе®үе…Ёпјү\n36:  * - Hash еӯҳжҜҸдёӘе•Ҷе“Ғпјҡж”№дёҖдёӘе•Ҷе“Ғж•°йҮҸпјҢзӣҙжҺҘ HINCRBY дёҖжқЎе‘Ҫд»Өжҗһе®ҡпјҲеҺҹеӯҗж“ҚдҪңпјҢзәҝзЁӢе®үе…Ёпјү\n37:  */\n38: @Slf4j\n39: @Service\n40: @RequiredArgsConstructor\n41: public class CartServiceImpl implements CartService {\n42: \n43:     private final RedisTemplate<String, Object> redisTemplate;\n44:     private final ProductFeignClient productFeignClient;\n45: \n46:     /**\n47:      * Redis key еүҚзјҖ\n48:      * жҜҸдёӘз”ЁжҲ·зҡ„иҙӯзү©иҪҰ key ж јејҸпјҡcart:з”ЁжҲ·ID\n49:      */\n50:     private static final String CART_KEY_PREFIX = \"cart:\";\n51: \n52:     @Override\n53:     public void addItem(Long userId, CartDTO dto) {\n54:         String key = CART_KEY_PREFIX + userId;\n55:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n56: \n57:         // зӣҙжҺҘз”Ё HINCRBYпјҲеҺҹеӯҗйҖ’еўһпјүпјҢдёҚз®Ў key жҳҜеҗҰеӯҳеңЁпјҡ\n58:         // - key дёҚеӯҳеңЁ вҶ’ Redis иҮӘеҠЁеҲӣе»әпјҢд»Һ 0 ејҖе§ӢйҖ’еўһ\n59:         // - key е·ІеӯҳеңЁ вҶ’ еңЁеҺҹеҖјдёҠзҙҜеҠ \n60:         // дёҖжқЎе‘Ҫд»Өжҗһе®ҡпјҢжІЎжңүз«һжҖҒжқЎд»¶\n61:         hashOps.increment(key, dto.getSkuId().toString(), dto.getQuantity());\n62:         log.info(\"з”ЁжҲ· {} иҙӯзү©иҪҰ SKU {} ж•°йҮҸ +{}\", userId, dto.getSkuId(), dto.getQuantity());\n63:     }\n64: \n65:     @Override\n66:     public void updateQuantity(Long userId, CartDTO dto) {\n67:         String key = CART_KEY_PREFIX + userId;\n68:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n69: \n70:         // жЈҖжҹҘе•Ҷе“ҒжҳҜеҗҰеңЁиҙӯзү©иҪҰдёӯ\n71:         if (!hashOps.hasKey(key, dto.getSkuId().toString())) {\n72:             throw new BizException(40021, \"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\");\n73:         }\n74: \n75:         // зӣҙжҺҘиҰҶзӣ–ж•°йҮҸ\n76:         hashOps.put(key, dto.getSkuId().toString(), dto.getQuantity());\n77:         log.info(\"з”ЁжҲ· {} иҙӯзү©иҪҰ SKU {} ж•°йҮҸдҝ®ж”№дёә {}\", userId, dto.getSkuId(), dto.getQuantity());\n78:     }\n79: \n80:     @Override\n81:     public void deleteItem(Long userId, Long skuId) {\n82:         String key = CART_KEY_PREFIX + userId;\n83:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n84: \n85:         // HDEL е‘Ҫд»ӨпјҡеҲ йҷӨ Hash дёӯзҡ„жҢҮе®ҡ field\n86:         Long deleted = hashOps.delete(key, skuId.toString());\n87:         if (deleted == null || deleted == 0) {\n88:             throw new BizException(40022, \"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\");\n89:         }\n90:         log.info(\"з”ЁжҲ· {} иҙӯзү©иҪҰеҲ йҷӨ SKU {}\", userId, skuId);\n91:     }\n92: \n93:     @Override\n94:     public List<CartItemVO> listItems(Long userId) {\n95:         String key = CART_KEY_PREFIX + userId;\n96:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n97: \n98:         // HGETALLпјҡиҺ·еҸ– Hash дёӯжүҖжңүзҡ„ field-value еҜ№\n99:         Map<Object, Object> entries = hashOps.entries(key);\n100:         if (entries.isEmpty()) {\n101:             return Collections.emptyList();\n102:         }\n103: \n104:         // ж”¶йӣҶжүҖжңү SKU ID\n105:         List<Long> skuIds = new ArrayList<>();\n106:         for (Object hashKey : entries.keySet()) {\n107:             skuIds.add(Long.parseLong(hashKey.toString()));\n108:         }\n109: \n110:         // и°ғз”Ёе•Ҷе“ҒжңҚеҠЎпјҢжү№йҮҸжҹҘиҜў SKU дҝЎжҒҜ\n111:         // иҝҷе°ұжҳҜ OpenFeign зҡ„з”Ёжі•пјҡеғҸи°ғз”Ёжң¬ең°ж–№жі•дёҖж ·и°ғз”ЁиҝңзЁӢжңҚеҠЎ\n112:         Map<Long, SkuVO> skuInfoMap = fetchSkuInfo(skuIds);\n113: \n114:         // з»„иЈ…иҙӯзү©иҪҰеҲ—иЎЁ\n115:         List<CartItemVO> cartItems = new ArrayList<>();\n116:         for (Map.Entry<Object, Object> entry : entries.entrySet()) {\n117:             Long skuId = Long.parseLong(entry.getKey().toString());\n118:             // RedisConfig еҗҜз”ЁдәҶ activateDefaultTypingпјҢеҸҚеәҸеҲ—еҢ–еҮәжқҘе·Із»ҸжҳҜ IntegerпјҢзӣҙжҺҘејәиҪ¬\n119:             Integer quantity = (Integer) entry.getValue();\n120: \n121:             CartItemVO vo = new CartItemVO();\n122:             vo.setSkuId(skuId);\n123:             vo.setQuantity(quantity);\n124: \n125:             // д»Һе•Ҷе“ҒжңҚеҠЎиҝ”еӣһзҡ„ж•°жҚ®дёӯиЎҘе…Ёе•Ҷе“ҒдҝЎжҒҜ\n126:             SkuVO skuInfo = skuInfoMap.get(skuId);\n127:             if (skuInfo != null) {\n128:                 vo.setProductName(skuInfo.getSpec()); // з”Ё spec дҪңдёәе•Ҷе“ҒеҗҚеұ•зӨә\n129:                 vo.setSpec(skuInfo.getSpec());\n130:                 vo.setPrice(skuInfo.getPrice());\n131:                 vo.setImg(skuInfo.getImg());\n132:             } else {\n133:                 // е•Ҷе“ҒжңҚеҠЎжҹҘдёҚеҲ°пјҲеҸҜиғҪе·ІдёӢжһ¶пјүпјҢж Үи®°дёә\"е•Ҷе“Ғе·ІеӨұж•Ҳ\"\n134:                 vo.setProductName(\"е•Ҷе“Ғе·ІеӨұж•Ҳ\");\n135:                 vo.setSpec(\"--\");\n136:                 vo.setPrice(null);\n137:                 vo.setImg(null);\n138:             }\n139: \n140:             cartItems.add(vo);\n141:         }\n142: \n143:         return cartItems;\n144:     }\n145: \n146:     /**\n147:      * и°ғз”Ёе•Ҷе“ҒжңҚеҠЎжҹҘиҜў SKU дҝЎжҒҜ\n148:      *\n149:      * иҝҷйҮҢжј”зӨәдәҶ OpenFeign зҡ„е®һйҷ…з”Ёжі•пјҡ\n150:      * 1. жіЁе…Ҙ ProductFeignClientпјҲеңЁ mall-product-api жЁЎеқ—дёӯе®ҡд№үзҡ„жҺҘеҸЈпјү\n151:      * 2. зӣҙжҺҘи°ғз”ЁжҺҘеҸЈж–№жі•пјҢFeign иҮӘеҠЁеҸ‘ HTTP иҜ·жұӮеҲ°е•Ҷе“ҒжңҚеҠЎ\n152:      * 3. иҝ”еӣһеҖјиҮӘеҠЁеҸҚеәҸеҲ—еҢ–жҲҗ Java еҜ№иұЎ\n153:      *\n154:      * еҰӮжһңе•Ҷе“ҒжңҚеҠЎжҢӮдәҶжҖҺд№ҲеҠһпјҹ\n155:      * ProductFeignClient й…ҚзҪ®дәҶ FallbackFactoryпјҲйҷҚзә§е·ҘеҺӮпјүпјҢ\n156:      * и°ғз”ЁеӨұиҙҘж—¶дјҡиҝ”еӣһ Result.fail()пјҢдёҚдјҡи®©ж•ҙдёӘиҜ·жұӮеҙ©жәғгҖӮ\n157:      */\n158:     private Map<Long, SkuVO> fetchSkuInfo(List<Long> skuIds) {\n159:         Map<Long, SkuVO> resultMap = new HashMap<>();\n160: \n161:         for (Long skuId : skuIds) {\n162:             try {\n163:                 // и°ғз”Ёе•Ҷе“ҒжңҚеҠЎзҡ„ Feign е®ўжҲ·з«Ҝ\n164:                 // е®һйҷ…еҸ‘зҡ„ HTTP иҜ·жұӮпјҡGET http://product-service/api/product/sku/{skuId}\n165:                 // дҪҶдҪ еҸӘйңҖиҰҒеҶҷпјҡproductFeignClient.getSkuById(skuId)\n166:                 Result<SkuVO> result = productFeignClient.getSkuById(skuId);\n167:                 if (result != null && result.getCode() == 200 && result.getData() != null) {\n168:                     resultMap.put(skuId, result.getData());\n169:                 }\n170:             } catch (Exception e) {\n171:                 // Feign и°ғз”ЁеӨұиҙҘж—¶и®°еҪ•ж—Ҙеҝ—пјҢдёҚеҪұе“Қиҙӯзү©иҪҰеҲ—иЎЁиҝ”еӣһ\n172:                 log.warn(\"и°ғз”Ёе•Ҷе“ҒжңҚеҠЎжҹҘиҜў SKU {} еӨұиҙҘ: {}\", skuId, e.getMessage());\n173:             }\n174:         }\n175: \n176:         return resultMap;\n177:     }\n178: }\n\n(End of file - total 178 lines)\n</content>"},"sessionId":"ses_171455795ffeo63B76Yp50e4TY","timestamp":"2026-06-03T18:24:54.048Z","toolInput":"{\"filePath\":\"/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/main/java/com/beibu/mall/cart/service/impl/CartServiceImpl.java\"}","toolName":"read","toolOutput":"<path>/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/main/java/com/beibu/mall/cart/service/impl/CartServiceImpl.java</path>\n<type>file</type>\n<content>\n1: package com.beibu.mall.cart.service.impl;\n2: \n3: import com.beibu.mall.cart.api.dto.CartDTO;\n4: import com.beibu.mall.cart.api.dto.CartItemVO;\n5: import com.beibu.mall.cart.service.CartService;\n6: import com.beibu.mall.common.exception.BizException;\n7: import com.beibu.mall.common.result.Result;\n8: import com.beibu.mall.product.api.dto.SkuVO;\n9: import com.beibu.mall.product.api.feign.ProductFeignClient;\n10: import lombok.RequiredArgsConstructor;\n11: import lombok.extern.slf4j.Slf4j;\n12: import org.springframework.data.redis.core.HashOperations;\n13: import org.springframework.data.redis.core.RedisTemplate;\n14: import org.springframework.stereotype.Service;\n15: \n16: import java.util.*;\n17: \n18: /**\n19:  * иҙӯзү©иҪҰжңҚеҠЎе®һзҺ°зұ»\n20:  *\n21:  * ж ёеҝғжҖқи·Ҝпјҡ\n22:  * иҙӯзү©иҪҰж•°жҚ®еӯҳеңЁ Redis зҡ„ Hash з»“жһ„дёӯгҖӮ\n23:  *\n24:  * Redis Hash з»“жһ„зӨәж„Ҹпјҡ\n25:  * Key: cart:1001пјҲз”ЁжҲ·ID=1001 зҡ„иҙӯзү©иҪҰпјү\n26:  * в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\n27:  * в”Ӯ  Hash Key  в”Ӯ Hash Value  в”Ӯ\n28:  * в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\n29:  * в”Ӯ \"10086\"    в”Ӯ 2           в”Ӯ  вҶҗ SKU ID=10086пјҢж•°йҮҸ=2\n30:  * в”Ӯ \"10087\"    в”Ӯ 1           в”Ӯ  вҶҗ SKU ID=10087пјҢж•°йҮҸ=1\n31:  * в”Ӯ \"10090\"    в”Ӯ 3           в”Ӯ  вҶҗ SKU ID=10090пјҢж•°йҮҸ=3\n32:  * в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\n33:  *\n34:  * дёәд»Җд№Ҳз”Ё Hash иҖҢдёҚжҳҜ Stringпјҹ\n35:  * - String еӯҳж•ҙдёӘиҙӯзү©иҪҰпјҡж”№дёҖдёӘе•Ҷе“Ғж•°йҮҸпјҢиҰҒиҜ»ж•ҙдёӘ JSON вҶ’ ж”№ вҶ’ еҶҷеӣһеҺ»пјҲе№¶еҸ‘дёҚе®үе…Ёпјү\n36:  * - Hash еӯҳжҜҸдёӘе•Ҷе“Ғпјҡж”№дёҖдёӘе•Ҷе“Ғж•°йҮҸпјҢзӣҙжҺҘ HINCRBY дёҖжқЎе‘Ҫд»Өжҗһе®ҡпјҲеҺҹеӯҗж“ҚдҪңпјҢзәҝзЁӢе®үе…Ёпјү\n37:  */\n38: @Slf4j\n39: @Service\n40: @RequiredArgsConstructor\n41: public class CartServiceImpl implements CartService {\n42: \n43:     private final RedisTemplate<String, Object> redisTemplate;\n44:     private final ProductFeignClient productFeignClient;\n45: \n46:     /**\n47:      * Redis key еүҚзјҖ\n48:      * жҜҸдёӘз”ЁжҲ·зҡ„иҙӯзү©иҪҰ key ж јејҸпјҡcart:з”ЁжҲ·ID\n49:      */\n50:     private static final String CART_KEY_PREFIX = \"cart:\";\n51: \n52:     @Override\n53:     public void addItem(Long userId, CartDTO dto) {\n54:         String key = CART_KEY_PREFIX + userId;\n55:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n56: \n57:         // зӣҙжҺҘз”Ё HINCRBYпјҲеҺҹеӯҗйҖ’еўһпјүпјҢдёҚз®Ў key жҳҜеҗҰеӯҳеңЁпјҡ\n58:         // - key дёҚеӯҳеңЁ вҶ’ Redis иҮӘеҠЁеҲӣе»әпјҢд»Һ 0 ејҖе§ӢйҖ’еўһ\n59:         // - key е·ІеӯҳеңЁ вҶ’ еңЁеҺҹеҖјдёҠзҙҜеҠ \n60:         // дёҖжқЎе‘Ҫд»Өжҗһе®ҡпјҢжІЎжңүз«һжҖҒжқЎд»¶\n61:         hashOps.increment(key, dto.getSkuId().toString(), dto.getQuantity());\n62:         log.info(\"з”ЁжҲ· {} иҙӯзү©иҪҰ SKU {} ж•°йҮҸ +{}\", userId, dto.getSkuId(), dto.getQuantity());\n63:     }\n64: \n65:     @Override\n66:     public void updateQuantity(Long userId, CartDTO dto) {\n67:         String key = CART_KEY_PREFIX + userId;\n68:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n69: \n70:         // жЈҖжҹҘе•Ҷе“ҒжҳҜеҗҰеңЁиҙӯзү©иҪҰдёӯ\n71:         if (!hashOps.hasKey(key, dto.getSkuId().toString())) {\n72:             throw new BizException(40021, \"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\");\n73:         }\n74: \n75:         // зӣҙжҺҘиҰҶзӣ–ж•°йҮҸ\n76:         hashOps.put(key, dto.getSkuId().toString(), dto.getQuantity());\n77:         log.info(\"з”ЁжҲ· {} иҙӯзү©иҪҰ SKU {} ж•°йҮҸдҝ®ж”№дёә {}\", userId, dto.getSkuId(), dto.getQuantity());\n78:     }\n79: \n80:     @Override\n81:     public void deleteItem(Long userId, Long skuId) {\n82:         String key = CART_KEY_PREFIX + userId;\n83:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n84: \n85:         // HDEL е‘Ҫд»ӨпјҡеҲ йҷӨ Hash дёӯзҡ„жҢҮе®ҡ field\n86:         Long deleted = hashOps.delete(key, skuId.toString());\n87:         if (deleted == null || deleted == 0) {\n88:             throw new BizException(40022, \"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\");\n89:         }\n90:         log.info(\"з”ЁжҲ· {} иҙӯзү©иҪҰеҲ йҷӨ SKU {}\", userId, skuId);\n91:     }\n92: \n93:     @Override\n94:     public List<CartItemVO> listItems(Long userId) {\n95:         String key = CART_KEY_PREFIX + userId;\n96:         HashOperations<String, Object, Object> hashOps = redisTemplate.opsForHash();\n97: \n98:         // HGETALLпјҡиҺ·еҸ– Hash дёӯжүҖжңүзҡ„ field-value еҜ№\n99:         Map<Object, Object> entries = hashOps.entries(key);\n100:         if (entries.isEmpty()) {\n101:             return Collections.emptyList();\n102:         }\n103: \n104:         // ж”¶йӣҶжүҖжңү SKU ID\n105:         List<Long> skuIds = new ArrayList<>();\n106:         for (Object hashKey : entries.keySet()) {\n107:             skuIds.add(Long.parseLong(hashKey.toString()));\n108:         }\n109: \n110:         // и°ғз”Ёе•Ҷе“ҒжңҚеҠЎпјҢжү№йҮҸжҹҘиҜў SKU дҝЎжҒҜ\n111:         // иҝҷе°ұжҳҜ OpenFeign зҡ„з”Ёжі•пјҡеғҸи°ғз”Ёжң¬ең°ж–№жі•дёҖж ·и°ғз”ЁиҝңзЁӢжңҚеҠЎ\n112:         Map<Long, SkuVO> skuInfoMap = fetchSkuInfo(skuIds);\n113: \n114:         // з»„иЈ…иҙӯзү©иҪҰеҲ—иЎЁ\n115:         List<CartItemVO> cartItems = new ArrayList<>();\n116:         for (Map.Entry<Object, Object> entry : entries.entrySet()) {\n117:             Long skuId = Long.parseLong(entry.getKey().toString());\n118:             // RedisConfig еҗҜз”ЁдәҶ activateDefaultTypingпјҢеҸҚеәҸеҲ—еҢ–еҮәжқҘе·Із»ҸжҳҜ IntegerпјҢзӣҙжҺҘејәиҪ¬\n119:             Integer quantity = (Integer) entry.getValue();\n120: \n121:             CartItemVO vo = new CartItemVO();\n122:             vo.setSkuId(skuId);\n123:             vo.setQuantity(quantity);\n124: \n125:             // д»Һе•Ҷе“ҒжңҚеҠЎиҝ”еӣһзҡ„ж•°жҚ®дёӯиЎҘе…Ёе•Ҷе“ҒдҝЎжҒҜ\n126:             SkuVO skuInfo = skuInfoMap.get(skuId);\n127:             if (skuInfo != null) {\n128:                 vo.setProductName(skuInfo.getSpec()); // з”Ё spec дҪңдёәе•Ҷе“ҒеҗҚеұ•зӨә\n129:                 vo.setSpec(skuInfo.getSpec());\n130:                 vo.setPrice(skuInfo.getPrice());\n131:                 vo.setImg(skuInfo.getImg());\n132:             } else {\n133:                 // е•Ҷе“ҒжңҚеҠЎжҹҘдёҚеҲ°пјҲеҸҜиғҪе·ІдёӢжһ¶пјүпјҢж Үи®°дёә\"е•Ҷе“Ғе·ІеӨұж•Ҳ\"\n134:                 vo.setProductName(\"е•Ҷе“Ғе·ІеӨұж•Ҳ\");\n135:                 vo.setSpec(\"--\");\n136:                 vo.setPrice(null);\n137:                 vo.setImg(null);\n138:             }\n139: \n140:             cartItems.add(vo);\n141:         }\n142: \n143:         return cartItems;\n144:     }\n145: \n146:     /**\n147:      * и°ғз”Ёе•Ҷе“ҒжңҚеҠЎжҹҘиҜў SKU дҝЎжҒҜ\n148:      *\n149:      * иҝҷйҮҢжј”зӨәдәҶ OpenFeign зҡ„е®һйҷ…з”Ёжі•пјҡ\n150:      * 1. жіЁе…Ҙ ProductFeignClientпјҲеңЁ mall-product-api жЁЎеқ—дёӯе®ҡд№үзҡ„жҺҘеҸЈпјү\n151:      * 2. зӣҙжҺҘи°ғз”ЁжҺҘеҸЈж–№жі•пјҢFeign иҮӘеҠЁеҸ‘ HTTP иҜ·жұӮеҲ°е•Ҷе“ҒжңҚеҠЎ\n152:      * 3. иҝ”еӣһеҖјиҮӘеҠЁеҸҚеәҸеҲ—еҢ–жҲҗ Java еҜ№иұЎ\n153:      *\n154:      * еҰӮжһңе•Ҷе“ҒжңҚеҠЎжҢӮдәҶжҖҺд№ҲеҠһпјҹ\n155:      * ProductFeignClient й…ҚзҪ®дәҶ FallbackFactoryпјҲйҷҚзә§е·ҘеҺӮпјүпјҢ\n156:      * и°ғз”ЁеӨұиҙҘж—¶дјҡиҝ”еӣһ Result.fail()пјҢдёҚдјҡи®©ж•ҙдёӘиҜ·жұӮеҙ©жәғгҖӮ\n157:      */\n158:     private Map<Long, SkuVO> fetchSkuInfo(List<Long> skuIds) {\n159:         Map<Long, SkuVO> resultMap = new HashMap<>();\n160: \n161:         for (Long skuId : skuIds) {\n162:             try {\n163:                 // и°ғз”Ёе•Ҷе“ҒжңҚеҠЎзҡ„ Feign е®ўжҲ·з«Ҝ\n164:                 // е®һйҷ…еҸ‘зҡ„ HTTP иҜ·жұӮпјҡGET http://product-service/api/product/sku/{skuId}\n165:                 // дҪҶдҪ еҸӘйңҖиҰҒеҶҷпјҡproductFeignClient.getSkuById(skuId)\n166:                 Result<SkuVO> result = productFeignClient.getSkuById(skuId);\n167:                 if (result != null && result.getCode() == 200 && result.getData() != null) {\n168:                     resultMap.put(skuId, result.getData());\n169:                 }\n170:             } catch (Exception e) {\n171:                 // Feign и°ғз”ЁеӨұиҙҘж—¶и®°еҪ•ж—Ҙеҝ—пјҢдёҚеҪұе“Қиҙӯзү©иҪҰеҲ—иЎЁиҝ”еӣһ\n172:                 log.warn(\"и°ғз”Ёе•Ҷе“ҒжңҚеҠЎжҹҘиҜў SKU {} еӨұиҙҘ: {}\", skuId, e.getMessage());\n173:             }\n174:         }\n175: \n176:         return resultMap;\n177:     }\n178: }\n\n(End of file - total 178 lines)\n</content>"},"type":"raw"},"obs_mpyec1nf_2ee8c45b5d7c":{"observation":{"hookType":"post_tool_use","id":"obs_mpyec1nf_2ee8c45b5d7c","raw":{"attachments":[],"call_id":"call_fce10b257b1b4349bd2c2f4a","duration_ms":49,"metadata":{"loaded":[],"preview":"package com.beibu.mall.cart.service;\n\nimport com.beibu.mall.cart.api.dto.CartDTO;\nimport com.beibu.mall.cart.api.dto.CartItemVO;\nimport com.beibu.mall.cart.service.impl.CartServiceImpl;\nimport com.beibu.mall.common.exception.BizException;\nimport com.beibu.mall.common.result.Result;\nimport com.beibu.mall.product.api.dto.SkuVO;\nimport com.beibu.mall.product.api.feign.ProductFeignClient;\nimport org.junit.jupiter.api.BeforeEach;\nimport org.junit.jupiter.api.DisplayName;\nimport org.junit.jupiter.api.Test;\nimport org.junit.jupiter.api.extension.ExtendWith;\nimport org.mockito.InjectMocks;\nimport org.mockito.Mock;\nimport org.mockito.junit.jupiter.MockitoExtension;\nimport org.springframework.data.redis.core.HashOperations;\nimport org.springframework.data.redis.core.RedisTemplate;\n\nimport java.math.BigDecimal;","truncated":false},"title":"beibu-mall/mall-cart/mall-cart-server/src/test/java/com/beibu/mall/cart/service/CartServiceTest.java","tool_input":"{\"filePath\":\"/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/test/java/com/beibu/mall/cart/service/CartServiceTest.java\"}","tool_name":"read","tool_output":"<path>/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/test/java/com/beibu/mall/cart/service/CartServiceTest.java</path>\n<type>file</type>\n<content>\n1: package com.beibu.mall.cart.service;\n2: \n3: import com.beibu.mall.cart.api.dto.CartDTO;\n4: import com.beibu.mall.cart.api.dto.CartItemVO;\n5: import com.beibu.mall.cart.service.impl.CartServiceImpl;\n6: import com.beibu.mall.common.exception.BizException;\n7: import com.beibu.mall.common.result.Result;\n8: import com.beibu.mall.product.api.dto.SkuVO;\n9: import com.beibu.mall.product.api.feign.ProductFeignClient;\n10: import org.junit.jupiter.api.BeforeEach;\n11: import org.junit.jupiter.api.DisplayName;\n12: import org.junit.jupiter.api.Test;\n13: import org.junit.jupiter.api.extension.ExtendWith;\n14: import org.mockito.InjectMocks;\n15: import org.mockito.Mock;\n16: import org.mockito.junit.jupiter.MockitoExtension;\n17: import org.springframework.data.redis.core.HashOperations;\n18: import org.springframework.data.redis.core.RedisTemplate;\n19: \n20: import java.math.BigDecimal;\n21: import java.util.*;\n22: \n23: import static org.junit.jupiter.api.Assertions.*;\n24: import static org.mockito.ArgumentMatchers.*;\n25: import static org.mockito.Mockito.*;\n26: \n27: /**\n28:  * иҙӯзү©иҪҰжңҚеҠЎеҚ•е…ғжөӢиҜ•\n29:  *\n30:  * жөӢиҜ•жҖқи·Ҝпјҡ\n31:  * - Mock жҺү Redis е’Ң FeignпјҲеӨ–йғЁдҫқиө–пјүпјҢеҸӘжөӢ Service еұӮйҖ»иҫ‘\n32:  * - йӘҢиҜҒпјҡжӯЈзЎ®и°ғз”ЁдәҶ Redis е‘Ҫд»ӨгҖҒжӯЈзЎ®еӨ„зҗҶдәҶејӮеёёжғ…еҶө\n33:  */\n34: @ExtendWith(MockitoExtension.class)\n35: class CartServiceTest {\n36: \n37:     @Mock\n38:     private RedisTemplate<String, Object> redisTemplate;\n39: \n40:     @Mock\n41:     private ProductFeignClient productFeignClient;\n42: \n43:     @Mock\n44:     private HashOperations<String, Object, Object> hashOperations;\n45: \n46:     @InjectMocks\n47:     private CartServiceImpl cartService;\n48: \n49:     private static final Long USER_ID = 1001L;\n50:     private static final Long SKU_ID = 10086L;\n51:     private static final String CART_KEY = \"cart:\" + USER_ID;\n52: \n53:     @BeforeEach\n54:     void setUp() {\n55:         // и®© redisTemplate.opsForHash() иҝ”еӣһжҲ‘д»¬зҡ„ mock еҜ№иұЎ\n56:         lenient().when(redisTemplate.opsForHash()).thenReturn(hashOperations);\n57:     }\n58: \n59:     // ========== еҠ е…Ҙиҙӯзү©иҪҰ ==========\n60: \n61:     @Test\n62:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - ж–°е•Ҷе“ҒпјҢзӣҙжҺҘйҖ’еўһ\")\n63:     void addItem_newItem() {\n64:         CartDTO dto = new CartDTO();\n65:         dto.setSkuId(SKU_ID);\n66:         dto.setQuantity(2);\n67: \n68:         // ж— и®ә key жҳҜеҗҰеӯҳеңЁпјҢйғҪз”Ё HINCRBY еҺҹеӯҗйҖ’еўһ\n69:         cartService.addItem(USER_ID, dto);\n70: \n71:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 2);\n72:         verify(hashOperations, never()).put(anyString(), anyString(), anyInt());\n73:     }\n74: \n75:     @Test\n76:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - е·Іжңүе•Ҷе“ҒпјҢзҙҜеҠ ж•°йҮҸ\")\n77:     void addItem_existingItem() {\n78:         CartDTO dto = new CartDTO();\n79:         dto.setSkuId(SKU_ID);\n80:         dto.setQuantity(3);\n81: \n82:         // HINCRBY еңЁеҺҹеҖјдёҠзҙҜеҠ пјҢж— йңҖе…ҲжҹҘеҶҚж”№\n83:         cartService.addItem(USER_ID, dto);\n84: \n85:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 3);\n86:     }\n87: \n88:     @Test\n89:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - жңҖе°Ҹж•°йҮҸ 1\")\n90:     void addItem_minQuantity() {\n91:         CartDTO dto = new CartDTO();\n92:         dto.setSkuId(SKU_ID);\n93:         dto.setQuantity(1);\n94: \n95:         cartService.addItem(USER_ID, dto);\n96: \n97:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 1);\n98:     }\n99: \n100:     @Test\n101:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - дёҚеҗҢ SKU дә’дёҚеҪұе“Қ\")\n102:     void addItem_multipleSkus() {\n103:         Long skuId2 = 10087L;\n104: \n105:         CartDTO dto1 = new CartDTO();\n106:         dto1.setSkuId(SKU_ID);\n107:         dto1.setQuantity(2);\n108: \n109:         CartDTO dto2 = new CartDTO();\n110:         dto2.setSkuId(skuId2);\n111:         dto2.setQuantity(5);\n112: \n113:         cartService.addItem(USER_ID, dto1);\n114:         cartService.addItem(USER_ID, dto2);\n115: \n116:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 2);\n117:         verify(hashOperations).increment(CART_KEY, skuId2.toString(), 5);\n118:     }\n119: \n120:     // ========== дҝ®ж”№ж•°йҮҸ ==========\n121: \n122:     @Test\n123:     @DisplayName(\"дҝ®ж”№ж•°йҮҸ - жҲҗеҠҹ\")\n124:     void updateQuantity_success() {\n125:         CartDTO dto = new CartDTO();\n126:         dto.setSkuId(SKU_ID);\n127:         dto.setQuantity(5);\n128: \n129:         when(hashOperations.hasKey(CART_KEY, SKU_ID.toString())).thenReturn(true);\n130: \n131:         cartService.updateQuantity(USER_ID, dto);\n132: \n133:         // йӘҢиҜҒпјҡи°ғз”ЁдәҶ HSET е‘Ҫд»ӨиҰҶзӣ–ж•°йҮҸ\n134:         verify(hashOperations).put(CART_KEY, SKU_ID.toString(), 5);\n135:     }\n136: \n137:     @Test\n138:     @DisplayName(\"дҝ®ж”№ж•°йҮҸ - е•Ҷе“ҒдёҚеңЁиҙӯзү©иҪҰдёӯ\")\n139:     void updateQuantity_notInCart() {\n140:         CartDTO dto = new CartDTO();\n141:         dto.setSkuId(SKU_ID);\n142:         dto.setQuantity(5);\n143: \n144:         when(hashOperations.hasKey(CART_KEY, SKU_ID.toString())).thenReturn(false);\n145: \n146:         BizException ex = assertThrows(BizException.class,\n147:                 () -> cartService.updateQuantity(USER_ID, dto));\n148: \n149:         assertEquals(40021, ex.getCode());\n150:         assertEquals(\"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\", ex.getMessage());\n151:     }\n152: \n153:     // ========== еҲ йҷӨе•Ҷе“Ғ ==========\n154: \n155:     @Test\n156:     @DisplayName(\"еҲ йҷӨе•Ҷе“Ғ - жҲҗеҠҹ\")\n157:     void deleteItem_success() {\n158:         when(hashOperations.delete(CART_KEY, SKU_ID.toString())).thenReturn(1L);\n159: \n160:         cartService.deleteItem(USER_ID, SKU_ID);\n161: \n162:         // йӘҢиҜҒпјҡи°ғз”ЁдәҶ HDEL е‘Ҫд»Ө\n163:         verify(hashOperations).delete(CART_KEY, SKU_ID.toString());\n164:     }\n165: \n166:     @Test\n167:     @DisplayName(\"еҲ йҷӨе•Ҷе“Ғ - е•Ҷе“ҒдёҚеңЁиҙӯзү©иҪҰдёӯ\")\n168:     void deleteItem_notInCart() {\n169:         when(hashOperations.delete(CART_KEY, SKU_ID.toString())).thenReturn(0L);\n170: \n171:         BizException ex = assertThrows(BizException.class,\n172:                 () -> cartService.deleteItem(USER_ID, SKU_ID));\n173: \n174:         assertEquals(40022, ex.getCode());\n175:         assertEquals(\"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\", ex.getMessage());\n176:     }\n177: \n178:     // ========== жҹҘзңӢиҙӯзү©иҪҰеҲ—иЎЁ ==========\n179: \n180:     @Test\n181:     @DisplayName(\"жҹҘзңӢиҙӯзү©иҪҰ - з©әиҙӯзү©иҪҰ\")\n182:     void listItems_emptyCart() {\n183:         when(hashOperations.entries(CART_KEY)).thenReturn(Collections.emptyMap());\n184: \n185:         List<CartItemVO> items = cartService.listItems(USER_ID);\n186: \n187:         assertNotNull(items);\n188:         assertTrue(items.isEmpty());\n189:     }\n190: \n191:     @Test\n192:     @DisplayName(\"жҹҘзңӢиҙӯзү©иҪҰ - жңүе•Ҷе“ҒпјҢFeign и°ғз”ЁжҲҗеҠҹ\")\n193:     void listItems_withItems() {\n194:         // иҙӯзү©иҪҰдёӯжңү 1 дёӘ SKU\n195:         Map<Object, Object> entries = new HashMap<>();\n196:         entries.put(SKU_ID.toString(), 2);\n197:         when(hashOperations.entries(CART_KEY)).thenReturn(entries);\n198: \n199:         // Mock е•Ҷе“ҒжңҚеҠЎиҝ”еӣһ\n200:         SkuVO skuVO = new SkuVO();\n201:         skuVO.setId(SKU_ID);\n202:         skuVO.setSpec(\"йІңжҙ»/500g\");\n203:         skuVO.setPrice(new BigDecimal(\"89.00\"));\n204:         skuVO.setImg(\"http://img.test/shrimp.jpg\");\n205:         when(productFeignClient.getSkuById(SKU_ID)).thenReturn(Result.ok(skuVO));\n206: \n207:         List<CartItemVO> items = cartService.listItems(USER_ID);\n208: \n209:         assertEquals(1, items.size());\n210:         CartItemVO item = items.get(0);\n211:         assertEquals(SKU_ID, item.getSkuId());\n212:         assertEquals(2, item.getQuantity());\n213:         assertEquals(\"йІңжҙ»/500g\", item.getSpec());\n214:         assertEquals(new BigDecimal(\"89.00\"), item.getPrice());\n215:     }\n216: \n217:     @Test\n218:     @DisplayName(\"жҹҘзңӢиҙӯзү©иҪҰ - Feign и°ғз”ЁеӨұиҙҘпјҢе•Ҷе“ҒдҝЎжҒҜдёәз©ә\")\n219:     void listItems_feignFailure() {\n220:         Map<Object, Object> entries = new HashMap<>();\n221:         entries.put(SKU_ID.toString(), 1);\n222:         when(hashOperations.entries(CART_KEY)).thenReturn(entries);\n223: \n224:         // Feign и°ғз”ЁжҠӣејӮеёё\n225:         when(productFeignClient.getSkuById(SKU_ID)).thenThrow(new RuntimeException(\"жңҚеҠЎдёҚеҸҜз”Ё\"));\n226: \n227:         List<CartItemVO> items = cartService.listItems(USER_ID);\n228: \n229:         assertEq"},"sessionId":"ses_171455795ffeo63B76Yp50e4TY","timestamp":"2026-06-03T18:24:55.127Z","toolInput":"{\"filePath\":\"/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/test/java/com/beibu/mall/cart/service/CartServiceTest.java\"}","toolName":"read","toolOutput":"<path>/home/administrator/BeibuMall/beibu-mall/mall-cart/mall-cart-server/src/test/java/com/beibu/mall/cart/service/CartServiceTest.java</path>\n<type>file</type>\n<content>\n1: package com.beibu.mall.cart.service;\n2: \n3: import com.beibu.mall.cart.api.dto.CartDTO;\n4: import com.beibu.mall.cart.api.dto.CartItemVO;\n5: import com.beibu.mall.cart.service.impl.CartServiceImpl;\n6: import com.beibu.mall.common.exception.BizException;\n7: import com.beibu.mall.common.result.Result;\n8: import com.beibu.mall.product.api.dto.SkuVO;\n9: import com.beibu.mall.product.api.feign.ProductFeignClient;\n10: import org.junit.jupiter.api.BeforeEach;\n11: import org.junit.jupiter.api.DisplayName;\n12: import org.junit.jupiter.api.Test;\n13: import org.junit.jupiter.api.extension.ExtendWith;\n14: import org.mockito.InjectMocks;\n15: import org.mockito.Mock;\n16: import org.mockito.junit.jupiter.MockitoExtension;\n17: import org.springframework.data.redis.core.HashOperations;\n18: import org.springframework.data.redis.core.RedisTemplate;\n19: \n20: import java.math.BigDecimal;\n21: import java.util.*;\n22: \n23: import static org.junit.jupiter.api.Assertions.*;\n24: import static org.mockito.ArgumentMatchers.*;\n25: import static org.mockito.Mockito.*;\n26: \n27: /**\n28:  * иҙӯзү©иҪҰжңҚеҠЎеҚ•е…ғжөӢиҜ•\n29:  *\n30:  * жөӢиҜ•жҖқи·Ҝпјҡ\n31:  * - Mock жҺү Redis е’Ң FeignпјҲеӨ–йғЁдҫқиө–пјүпјҢеҸӘжөӢ Service еұӮйҖ»иҫ‘\n32:  * - йӘҢиҜҒпјҡжӯЈзЎ®и°ғз”ЁдәҶ Redis е‘Ҫд»ӨгҖҒжӯЈзЎ®еӨ„зҗҶдәҶејӮеёёжғ…еҶө\n33:  */\n34: @ExtendWith(MockitoExtension.class)\n35: class CartServiceTest {\n36: \n37:     @Mock\n38:     private RedisTemplate<String, Object> redisTemplate;\n39: \n40:     @Mock\n41:     private ProductFeignClient productFeignClient;\n42: \n43:     @Mock\n44:     private HashOperations<String, Object, Object> hashOperations;\n45: \n46:     @InjectMocks\n47:     private CartServiceImpl cartService;\n48: \n49:     private static final Long USER_ID = 1001L;\n50:     private static final Long SKU_ID = 10086L;\n51:     private static final String CART_KEY = \"cart:\" + USER_ID;\n52: \n53:     @BeforeEach\n54:     void setUp() {\n55:         // и®© redisTemplate.opsForHash() иҝ”еӣһжҲ‘д»¬зҡ„ mock еҜ№иұЎ\n56:         lenient().when(redisTemplate.opsForHash()).thenReturn(hashOperations);\n57:     }\n58: \n59:     // ========== еҠ е…Ҙиҙӯзү©иҪҰ ==========\n60: \n61:     @Test\n62:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - ж–°е•Ҷе“ҒпјҢзӣҙжҺҘйҖ’еўһ\")\n63:     void addItem_newItem() {\n64:         CartDTO dto = new CartDTO();\n65:         dto.setSkuId(SKU_ID);\n66:         dto.setQuantity(2);\n67: \n68:         // ж— и®ә key жҳҜеҗҰеӯҳеңЁпјҢйғҪз”Ё HINCRBY еҺҹеӯҗйҖ’еўһ\n69:         cartService.addItem(USER_ID, dto);\n70: \n71:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 2);\n72:         verify(hashOperations, never()).put(anyString(), anyString(), anyInt());\n73:     }\n74: \n75:     @Test\n76:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - е·Іжңүе•Ҷе“ҒпјҢзҙҜеҠ ж•°йҮҸ\")\n77:     void addItem_existingItem() {\n78:         CartDTO dto = new CartDTO();\n79:         dto.setSkuId(SKU_ID);\n80:         dto.setQuantity(3);\n81: \n82:         // HINCRBY еңЁеҺҹеҖјдёҠзҙҜеҠ пјҢж— йңҖе…ҲжҹҘеҶҚж”№\n83:         cartService.addItem(USER_ID, dto);\n84: \n85:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 3);\n86:     }\n87: \n88:     @Test\n89:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - жңҖе°Ҹж•°йҮҸ 1\")\n90:     void addItem_minQuantity() {\n91:         CartDTO dto = new CartDTO();\n92:         dto.setSkuId(SKU_ID);\n93:         dto.setQuantity(1);\n94: \n95:         cartService.addItem(USER_ID, dto);\n96: \n97:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 1);\n98:     }\n99: \n100:     @Test\n101:     @DisplayName(\"еҠ е…Ҙиҙӯзү©иҪҰ - дёҚеҗҢ SKU дә’дёҚеҪұе“Қ\")\n102:     void addItem_multipleSkus() {\n103:         Long skuId2 = 10087L;\n104: \n105:         CartDTO dto1 = new CartDTO();\n106:         dto1.setSkuId(SKU_ID);\n107:         dto1.setQuantity(2);\n108: \n109:         CartDTO dto2 = new CartDTO();\n110:         dto2.setSkuId(skuId2);\n111:         dto2.setQuantity(5);\n112: \n113:         cartService.addItem(USER_ID, dto1);\n114:         cartService.addItem(USER_ID, dto2);\n115: \n116:         verify(hashOperations).increment(CART_KEY, SKU_ID.toString(), 2);\n117:         verify(hashOperations).increment(CART_KEY, skuId2.toString(), 5);\n118:     }\n119: \n120:     // ========== дҝ®ж”№ж•°йҮҸ ==========\n121: \n122:     @Test\n123:     @DisplayName(\"дҝ®ж”№ж•°йҮҸ - жҲҗеҠҹ\")\n124:     void updateQuantity_success() {\n125:         CartDTO dto = new CartDTO();\n126:         dto.setSkuId(SKU_ID);\n127:         dto.setQuantity(5);\n128: \n129:         when(hashOperations.hasKey(CART_KEY, SKU_ID.toString())).thenReturn(true);\n130: \n131:         cartService.updateQuantity(USER_ID, dto);\n132: \n133:         // йӘҢиҜҒпјҡи°ғз”ЁдәҶ HSET е‘Ҫд»ӨиҰҶзӣ–ж•°йҮҸ\n134:         verify(hashOperations).put(CART_KEY, SKU_ID.toString(), 5);\n135:     }\n136: \n137:     @Test\n138:     @DisplayName(\"дҝ®ж”№ж•°йҮҸ - е•Ҷе“ҒдёҚеңЁиҙӯзү©иҪҰдёӯ\")\n139:     void updateQuantity_notInCart() {\n140:         CartDTO dto = new CartDTO();\n141:         dto.setSkuId(SKU_ID);\n142:         dto.setQuantity(5);\n143: \n144:         when(hashOperations.hasKey(CART_KEY, SKU_ID.toString())).thenReturn(false);\n145: \n146:         BizException ex = assertThrows(BizException.class,\n147:                 () -> cartService.updateQuantity(USER_ID, dto));\n148: \n149:         assertEquals(40021, ex.getCode());\n150:         assertEquals(\"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\", ex.getMessage());\n151:     }\n152: \n153:     // ========== еҲ йҷӨе•Ҷе“Ғ ==========\n154: \n155:     @Test\n156:     @DisplayName(\"еҲ йҷӨе•Ҷе“Ғ - жҲҗеҠҹ\")\n157:     void deleteItem_success() {\n158:         when(hashOperations.delete(CART_KEY, SKU_ID.toString())).thenReturn(1L);\n159: \n160:         cartService.deleteItem(USER_ID, SKU_ID);\n161: \n162:         // йӘҢиҜҒпјҡи°ғз”ЁдәҶ HDEL е‘Ҫд»Ө\n163:         verify(hashOperations).delete(CART_KEY, SKU_ID.toString());\n164:     }\n165: \n166:     @Test\n167:     @DisplayName(\"еҲ йҷӨе•Ҷе“Ғ - е•Ҷе“ҒдёҚеңЁиҙӯзү©иҪҰдёӯ\")\n168:     void deleteItem_notInCart() {\n169:         when(hashOperations.delete(CART_KEY, SKU_ID.toString())).thenReturn(0L);\n170: \n171:         BizException ex = assertThrows(BizException.class,\n172:                 () -> cartService.deleteItem(USER_ID, SKU_ID));\n173: \n174:         assertEquals(40022, ex.getCode());\n175:         assertEquals(\"иҙӯзү©иҪҰдёӯдёҚеӯҳеңЁиҜҘе•Ҷе“Ғ\", ex.getMessage());\n176:     }\n177: \n178:     // ========== жҹҘзңӢиҙӯзү©иҪҰеҲ—иЎЁ ==========\n179: \n180:     @Test\n181:     @DisplayName(\"жҹҘзңӢиҙӯзү©иҪҰ - з©әиҙӯзү©иҪҰ\")\n182:     void listItems_emptyCart() {\n183:         when(hashOperations.entries(CART_KEY)).thenReturn(Collections.emptyMap());\n184: \n185:         List<CartItemVO> items = cartService.listItems(USER_ID);\n186: \n187:         assertNotNull(items);\n188:         assertTrue(items.isEmpty());\n189:     }\n190: \n191:     @Test\n192:     @DisplayName(\"жҹҘзңӢиҙӯзү©иҪҰ - жңүе•Ҷе“ҒпјҢFeign и°ғз”ЁжҲҗеҠҹ\")\n193:     void listItems_withItems() {\n194:         // иҙӯзү©иҪҰдёӯжңү 1 дёӘ SKU\n195:         Map<Object, Object> entries = new HashMap<>();\n196:         entries.put(SKU_ID.toString(), 2);\n197:         when(hashOperations.entries(CART_KEY)).thenReturn(entries);\n198: \n199:         // Mock е•Ҷе“ҒжңҚеҠЎиҝ”еӣһ\n200:         SkuVO skuVO = new SkuVO();\n201:         skuVO.setId(SKU_ID);\n202:         skuVO.setSpec(\"йІңжҙ»/500g\");\n203:         skuVO.setPrice(new BigDecimal(\"89.00\"));\n204:         skuVO.setImg(\"http://img.test/shrimp.jpg\");\n205:         when(productFeignClient.getSkuById(SKU_ID)).thenReturn(Result.ok(skuVO));\n206: \n207:         List<CartItemVO> items = cartService.listItems(USER_ID);\n208: \n209:         assertEquals(1, items.size());\n210:         CartItemVO item = items.get(0);\n211:         assertEquals(SKU_ID, item.getSkuId());\n212:         assertEquals(2, item.getQuantity());\n213:         assertEquals(\"йІңжҙ»/500g\", item.getSpec());\n214:         assertEquals(new BigDecimal(\"89.00\"), item.getPrice());\n215:     }\n216: \n217:     @Test\n218:     @DisplayName(\"жҹҘзңӢиҙӯзү©иҪҰ - Feign и°ғз”ЁеӨұиҙҘпјҢе•Ҷе“ҒдҝЎжҒҜдёәз©ә\")\n219:     void listItems_feignFailure() {\n220:         Map<Object, Object> entries = new HashMap<>();\n221:         entries.put(SKU_ID.toString(), 1);\n222:         when(hashOperations.entries(CART_KEY)).thenReturn(entries);\n223: \n224:         // Feign и°ғз”ЁжҠӣејӮеёё\n225:         when(productFeignClient.getSkuById(SKU_ID)).thenThrow(new RuntimeException(\"жңҚеҠЎдёҚеҸҜз”Ё\"));\n226: \n227:         List<CartItemVO> items = cartService.listItems(USER_ID);\n228: \n229:         assertEq"},"type":"raw"}}ёj␀Heюя